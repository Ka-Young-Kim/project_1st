generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Todo {
  id        String   @id @default(cuid())
  title     String
  priority  Priority
  dueDate   DateTime?
  completed Boolean  @default(false)
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model InvestmentLog {
  id        String      @id @default(cuid())
  tradeDate DateTime
  symbol    String
  action    TradeAction
  quantity  Decimal
  price     Decimal
  reason    String
  review    String?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
}

enum Priority {
  low
  medium
  high
}

enum TradeAction {
  buy
  sell
}
