generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Todo {
  id        String   @id @default(cuid())
  title     String
  priority  Priority
  dueDate   DateTime?
  completed Boolean  @default(false)
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model InvestmentLog {
  id               String             @id @default(cuid())
  tradeDate        DateTime
  portfolioId      String?
  portfolio        Portfolio?         @relation(fields: [portfolioId], references: [id], onDelete: SetNull)
  portfolioAccountId String?
  portfolioAccount PortfolioAccount?  @relation(fields: [portfolioAccountId], references: [id], onDelete: SetNull)
  investmentItemId String?
  investmentItem   InvestmentItem?    @relation(fields: [investmentItemId], references: [id], onDelete: SetNull)
  symbol           String
  action           TradeAction
  quantity         Decimal
  price            Decimal
  reason           String
  review           String?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
}

model InvestmentItem {
  id           String             @id @default(cuid())
  portfolioId  String?
  portfolio    Portfolio?         @relation(fields: [portfolioId], references: [id], onDelete: SetNull)
  name         String
  code         String
  quoteSymbol  String?
  exchange     String?
  currency     String?
  category     String?
  industry     String?
  notes        String?
  active       Boolean            @default(true)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  logs         InvestmentLog[]
  holdings     PortfolioHolding[]
  portfolioItems PortfolioItem[]

  @@unique([portfolioId, code])
}

model Portfolio {
  id            String                @id @default(cuid())
  name          String
  description   String?
  active        Boolean               @default(true)
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  items         InvestmentItem[]
  logs          InvestmentLog[]
  accounts      PortfolioAccount[]
  assetGroups   PortfolioAssetGroup[]
  holdings      PortfolioHolding[]
  portfolioItems PortfolioItem[]
  snapshots     PortfolioSnapshot[]
}

model PortfolioAccount {
  id                 String                @id @default(cuid())
  portfolioId        String
  portfolio          Portfolio             @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  name               String
  nickname           String?
  displayId          String?
  sortOrder          Int                   @default(0)
  cashTrackingEnabled Boolean              @default(false)
  cashBalance        Decimal               @default(0)
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  logs               InvestmentLog[]
  portfolioItems     PortfolioItem[]
  snapshots          PortfolioAccountSnapshot[]

  @@unique([portfolioId, name])
}

model PortfolioAssetGroup {
  id          String                       @id @default(cuid())
  portfolioId String
  portfolio   Portfolio                    @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  name        String
  targetWeight Decimal
  sortOrder   Int                          @default(0)
  createdAt   DateTime                     @default(now())
  updatedAt   DateTime                     @updatedAt
  holdings    PortfolioHolding[]
  portfolioItems PortfolioItem[]
  snapshots   PortfolioAssetGroupSnapshot[]
  holdingSnapshots PortfolioHoldingSnapshot[]

  @@unique([portfolioId, name])
}

model PortfolioItem {
  id                    String               @id @default(cuid())
  portfolioId           String
  portfolio             Portfolio            @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  linkedInvestmentItemId String?
  linkedInvestmentItem  InvestmentItem?      @relation(fields: [linkedInvestmentItemId], references: [id], onDelete: SetNull)
  portfolioAccountId    String?
  portfolioAccount      PortfolioAccount?    @relation(fields: [portfolioAccountId], references: [id], onDelete: SetNull)
  portfolioAssetGroupId String?
  portfolioAssetGroup   PortfolioAssetGroup? @relation(fields: [portfolioAssetGroupId], references: [id], onDelete: SetNull)
  name                  String
  code                  String
  quantity              Decimal              @default(0)
  averagePrice          Decimal              @default(0)
  currentPrice          Decimal              @default(0)
  notes                 String?
  active                Boolean              @default(true)
  sortOrder             Int                  @default(0)
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt

  @@index([portfolioId, sortOrder])
  @@index([linkedInvestmentItemId])
  @@index([portfolioAccountId])
  @@index([portfolioAssetGroupId])
}

model PortfolioHolding {
  id                   String              @id @default(cuid())
  portfolioId          String
  portfolio            Portfolio           @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  investmentItemId     String
  investmentItem       InvestmentItem      @relation(fields: [investmentItemId], references: [id], onDelete: Cascade)
  portfolioAssetGroupId String?
  portfolioAssetGroup  PortfolioAssetGroup? @relation(fields: [portfolioAssetGroupId], references: [id], onDelete: SetNull)
  active               Boolean             @default(true)
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  snapshots            PortfolioHoldingSnapshot[]

  @@unique([portfolioId, investmentItemId])
}

model PortfolioSnapshot {
  id             String                     @id @default(cuid())
  portfolioId    String
  portfolio      Portfolio                  @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  snapshotDate   DateTime
  investedAmount Decimal
  marketValue    Decimal
  profitAmount   Decimal
  profitRate     Decimal
  createdAt      DateTime                   @default(now())
  updatedAt      DateTime                   @updatedAt
  assetGroups    PortfolioAssetGroupSnapshot[]
  holdings       PortfolioHoldingSnapshot[]
  accounts       PortfolioAccountSnapshot[]

  @@unique([portfolioId, snapshotDate])
}

model PortfolioAssetGroupSnapshot {
  id                 String                @id @default(cuid())
  portfolioSnapshotId String
  portfolioSnapshot  PortfolioSnapshot     @relation(fields: [portfolioSnapshotId], references: [id], onDelete: Cascade)
  portfolioAssetGroupId String?
  portfolioAssetGroup PortfolioAssetGroup? @relation(fields: [portfolioAssetGroupId], references: [id], onDelete: SetNull)
  name               String
  targetWeight       Decimal
  currentWeight      Decimal
  investedAmount     Decimal
  marketValue        Decimal
  profitAmount       Decimal
  profitRate         Decimal
  buyAmount          Decimal
  sellAmount         Decimal
  createdAt          DateTime              @default(now())
}

model PortfolioHoldingSnapshot {
  id                 String                @id @default(cuid())
  portfolioSnapshotId String
  portfolioSnapshot  PortfolioSnapshot     @relation(fields: [portfolioSnapshotId], references: [id], onDelete: Cascade)
  portfolioHoldingId String?
  portfolioHolding   PortfolioHolding?     @relation(fields: [portfolioHoldingId], references: [id], onDelete: SetNull)
  portfolioAssetGroupId String?
  portfolioAssetGroup PortfolioAssetGroup? @relation(fields: [portfolioAssetGroupId], references: [id], onDelete: SetNull)
  investmentItemId   String?
  code               String
  name               String
  quantity           Decimal
  averagePrice       Decimal
  currentPrice       Decimal
  currency           String
  investedAmount     Decimal
  marketValue        Decimal
  profitAmount       Decimal
  profitRate         Decimal
  createdAt          DateTime              @default(now())
}

model PortfolioAccountSnapshot {
  id                 String                @id @default(cuid())
  portfolioSnapshotId String
  portfolioSnapshot  PortfolioSnapshot     @relation(fields: [portfolioSnapshotId], references: [id], onDelete: Cascade)
  portfolioAccountId String?
  portfolioAccount   PortfolioAccount?     @relation(fields: [portfolioAccountId], references: [id], onDelete: SetNull)
  name               String
  displayId          String?
  investedAmount     Decimal
  marketValue        Decimal
  cashValue          Decimal
  createdAt          DateTime              @default(now())
}

model AppSettings {
  id               String   @id
  brandName        String
  brandSubtitle    String
  brandImageUrl    String?
  monthlyPrinciple String
  dashboardInsights String   @default("오늘 마감 TODO는 없어 계획 정리나 회고에 시간을 쓸 수 있습니다.\n이번 달 거래 0건으로 비교적 안정적인 기록 흐름입니다.\n완료율 0%로 열린 항목 정리가 더 필요합니다.")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

enum Priority {
  low
  medium
  high
}

enum TradeAction {
  buy
  sell
}
